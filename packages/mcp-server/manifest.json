{
  "dxt_version": "0.2",
  "name": "crosmos-mcp",
  "version": "0.1.0",
  "description": "The official MCP Server for the Crosmos API",
  "author": {
    "name": "Crosmos",
    "email": "support@crosmos.dev"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crosmos-labs/crosmos-ts-sdk.git"
  },
  "homepage": "https://github.com/crosmos-labs/crosmos-ts-sdk/tree/main/packages/mcp-server#readme",
  "documentation": "https://docs.crosmos.dev",
  "server": {
    "type": "node",
    "entry_point": "index.js",
    "mcp_config": {
      "command": "node",
      "args": [
        "${__dirname}/index.js"
      ],
      "env": {
        "CROSMOS_API_KEY": "${user_config.CROSMOS_API_KEY}"
      }
    }
  },
  "user_config": {
    "CROSMOS_API_KEY": {
      "title": "api_key",
      "description": "JWT access token or API key (csk_…)",
      "required": true,
      "type": "string"
    }
  },
  "tools": [],
  "tools_generated": true,
  "compatibility": {
    "runtimes": {
      "node": ">=18.0.0"
    }
  },
  "keywords": [
    "api"
  ]
}
